# FeeHunt licensing server
NODE_ENV=development
PORT=3001

# Public FeeHunt URLs
FEEHUNT_APP_URL=https://feehunt.pro
FEEHUNT_DOWNLOAD_URL=https://feehunt.pro/download

# Supabase
# Project Settings -> API -> Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Project Settings -> API -> service_role key
# Keep this secret. Never expose it in website JavaScript.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Backward-compatible alias. You can leave this empty if SUPABASE_SERVICE_ROLE_KEY is set.
SUPABASE_SERVICE_KEY=

# Optional direct database URL for applying supabase/schema.sql with psql.
# Project Settings -> Database -> Connection string -> URI
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Resend SMTP email delivery
# Resend -> API Keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# Resend -> Domains. Use a verified sender/domain.
EMAIL_FROM=support@feehunt.pro

# Optional SMTP override. Defaults are Resend SMTP.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
# SMTP_PASS can be used instead of RESEND_API_KEY.
SMTP_PASS=

# Stripe is not required for Phase 1 trial registration.
# Add this later when paid checkout is enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
